<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_device"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row 1: Name + Threat badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_device_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Device Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_threat_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH RISK"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:background="@drawable/bg_badge"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <!-- Row 2: MAC address + device type -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_device_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00:00:00:00:00:00"
                android:textSize="12sp"
                android:textColor="#616161"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tv_device_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BLE"
                android:textSize="11sp"
                android:textColor="#78909C"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

        </LinearLayout>

        <!-- Row 3: Manufacturer -->
        <TextView
            android:id="@+id/tv_manufacturer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Unknown manufacturer"
            android:textSize="12sp"
            android:textColor="#757575"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#E0E0E0" />

        <!-- Row 4: Threat reason -->
        <TextView
            android:id="@+id/tv_threat_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Threat reason"
            android:textSize="12sp"
            android:textColor="#424242"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Row 5: Signal bar + RSSI + seen count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <ProgressBar
                android:id="@+id/signal_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/tv_rssi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="-70 dBm"
                android:textSize="11sp"
                android:textColor="#616161" />

            <TextView
                android:id="@+id/tv_seen_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Seen 1×"
                android:textSize="11sp"
                android:textColor="#9E9E9E" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
